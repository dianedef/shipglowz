# ShipFlow environment variables
# Copy these into your shell/env before launching ShipFlow.

# Core paths
SHIPFLOW_PROJECTS_DIR=/home/user/shipflow-projects
SHIPFLOW_DATA_DIR=$HOME/shipglowz_data
SHIPFLOW_LOG_DIR=$HOME/.shipflow/logs
SHIPFLOW_LOG_FILE=$SHIPFLOW_LOG_DIR/shipflow.log
SHIPFLOW_CADDYFILE=/etc/caddy/Caddyfile
SHIPFLOW_SECRETS_DIR=$HOME/.shipflow
SHIPFLOW_SESSION_DIR=$SHIPFLOW_SECRETS_DIR/session

# Port management
SHIPFLOW_PORT_RANGE_START=3000
SHIPFLOW_PORT_RANGE_END=3100
SHIPFLOW_PORT_MAX_ATTEMPTS=100

# SSH tunnel defaults
SHIPFLOW_SSH_KEEPALIVE_INTERVAL=30
SHIPFLOW_SSH_KEEPALIVE_MAX=3
SHIPFLOW_SSH_REMOTE_USER=root
SHIPFLOW_SSH_REMOTE_HOST=hetzner

# Logging and monitoring
SHIPFLOW_LOGGING_ENABLED=true
SHIPFLOW_LOG_RETENTION_DAYS=30
SHIPFLOW_LOG_LEVEL=INFO
SHIPFLOW_GITHUB_REPO_LIMIT=500
SHIPFLOW_PM2_CACHE_ENABLED=true
SHIPFLOW_PM2_CACHE_TTL=5
SHIPFLOW_PREFER_JQ=true
SHIPFLOW_HEALTH_CHECK_ENABLED=true
SHIPFLOW_CRASH_LOOP_THRESHOLD=10
SHIPFLOW_UNSTABLE_UPTIME_SECS=30
SHIPFLOW_DISK_WARN_GB=5
SHIPFLOW_MENU_STATUS_CACHE_TTL=120
SHIPFLOW_MEM_WARN_GB=4
SHIPFLOW_PROCESS_LONG_RUNNING_HOURS=24
SHIPFLOW_MONITOR_TOP_N=15
SHIPFLOW_SESSION_ENABLED=true

# Screenshot / image upload
SHIPFLOW_IMGBB_API_KEY=your_imgbb_api_key_here

# Doppler + DataForSEO integration
SHIPFLOW_DOPPLER_MODE=auto
SHIPFLOW_ENABLE_DATAFORSEO_MCP=0
SHIPFLOW_DATAFORSEO_DOPPLER_PROJECT=contentflow_app
SHIPFLOW_DATAFORSEO_DOPPLER_CONFIG=prd
DATAFORSEO_USERNAME=your_dataforseo_username_here
DATAFORSEO_LOGIN=your_dataforseo_login_here
DATAFORSEO_PASSWORD=your_dataforseo_password_here

# Misc runtime behavior
SHIPFLOW_SCREENSHOT_EXPIRATION=600
SHIPFLOW_STRICT_MODE=false
SHIPFLOW_ERROR_TRAPS=true
