---
import { roleMapCopy, type Locale } from "../i18n/ui";
import SectionHeading from "./SectionHeading.astro";
import RoleList from "./RoleList.astro";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = roleMapCopy[locale];
---

<section class="section">
  <SectionHeading eyebrow={copy.eyebrow} title={copy.title} body={copy.body} />
  <RoleList items={copy.docs} />
</section>
