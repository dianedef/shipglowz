---
import { pathFor, sharedHomeSections, type Locale } from "../i18n/ui";
import SectionHeading from "./SectionHeading.astro";
import ItemCard from "./ItemCard.astro";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = sharedHomeSections[locale].docs;
---

<section class="section" id="docs-cta">
  <div class="docs-panel">
    <div>
      <SectionHeading eyebrow={copy.eyebrow} title={copy.title} body={copy.body} class="docs-panel-heading" />
    </div>

    <div class="docs-links">
      {copy.links.map(([label, href]) => (
        <ItemCard class="docs-link-card">
          <a class="docs-link" href={pathFor(href, locale)}>{label}</a>
        </ItemCard>
      ))}
    </div>
  </div>
</section>
