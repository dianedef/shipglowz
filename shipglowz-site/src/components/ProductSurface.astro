---
import { sharedHomeSections, type Locale } from "../i18n/ui";
import SectionHeading from "./SectionHeading.astro";
import ItemCard from "./ItemCard.astro";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = sharedHomeSections[locale].product;
---

<section class="section" id="how-it-works">
  <SectionHeading eyebrow={copy.eyebrow} title={copy.title} body={copy.body} />
  <div class="split-grid">
    {copy.panels.map(([title, items]) => (
      <ItemCard {title}>
        <ul class="check-list">
          {items.map((item) => <li>{item}</li>)}
        </ul>
      </ItemCard>
    ))}
  </div>
</section>
