---
import { pathFor, sharedHomeSections, type Locale } from "../i18n/ui";
import SectionHeading from "./SectionHeading.astro";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = sharedHomeSections[locale].cta;
---

<section class="section">
  <div class="cta-panel">
    <SectionHeading eyebrow={copy.eyebrow} title={copy.title} body={copy.body} class="cta-panel-heading" />
    <div class="hero-actions">
      {copy.actions.map(([label, href, className]) => (
        <a class={className} href={pathFor(href, locale)}>{label}</a>
      ))}
    </div>
  </div>
</section>
