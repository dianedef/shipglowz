---
import { homeCopy, pathFor, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = homeCopy[locale].hero;
const [primaryAction, ...secondaryActions] = copy.actions;
---

<section class="hero">
  <div class="hero-copy">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h1>{copy.title}</h1>
    <p class="hero-text">{copy.body}</p>
    <ul class="hero-points">
      {copy.points.map((point) => <li>{point}</li>)}
    </ul>
    <div class="hero-actions">
      <a class={`${primaryAction[2]} hero-action-primary`} href={pathFor(primaryAction[1], locale)}>
        {primaryAction[0]}
      </a>
      <div class="hero-actions-secondary">
        {secondaryActions.map(([label, href, className]) => <a class={className} href={pathFor(href, locale)}>{label}</a>)}
      </div>
    </div>
  </div>

  <div class="hero-panel">
    <div class="hero-map">
      {copy.blocks.map(([label, body]) => (
        <div class="hero-map-block">
          <span>{label}</span>
          <strong>{body}</strong>
        </div>
      ))}
      <div class="hero-map-note">
        {copy.note}
      </div>
    </div>
  </div>
</section>
