---
interface Props {
  eyebrow?: string;
  title: string;
  body?: string;
  class?: string;
}

const {
  eyebrow,
  title,
  body,
  class: className = "section-heading"
} = Astro.props;
---

<div class={className}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {body && <p>{body}</p>}
</div>
