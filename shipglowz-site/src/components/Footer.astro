---
import { footerCopy, pathFor, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = footerCopy[locale];
---

<footer class="site-footer">
  <div>
    <strong>ShipGlowz</strong>
    <p>{copy.body}</p>
  </div>
  <div class="footer-links">
    {copy.links.map(([label, href]) => <a href={pathFor(href, locale)}>{label}</a>)}
  </div>
</footer>
