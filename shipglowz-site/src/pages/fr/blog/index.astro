---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Footer from "../../../components/Footer.astro";
import NavBar from "../../../components/NavBar.astro";

const articles = (await getCollection("articles", ({ data }) => data.locale === "fr" && !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const featured = articles.find((article) => article.data.featured) ?? articles[0];
const rest = articles.filter((article) => article.id !== featured?.id);
---

<BaseLayout
  title="Blog ShipGlowz | Articles éditoriaux sur le runtime, les workflows et la livraison"
  description="Les articles longs de ShipGlowz sur les choix runtime, la discipline de workflow, la livraison et l’exécution assistée par IA."
  locale="fr"
  canonicalPath="/fr/blog"
  alternatePath="/blog"
>
  <main class="page-shell">
    <NavBar locale="fr" currentPath="/blog" />

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">Blog ShipGlowz</p>
        <h1 class="page-title">Une surface éditoriale pour détailler les décisions derrière le framework.</h1>
        <p>
          Les docs expliquent les contrats. Les skills expliquent les mouvements
          de workflow. Le blog sert à défendre une position quand une réponse
          demande plus qu’une carte ou qu’une FAQ.
        </p>
      </div>
    </section>

    {
      featured && (
        <section class="section">
          <article class="cta-panel">
            <p class="eyebrow">Article mis en avant</p>
            <h2>{featured.data.title}</h2>
            <p>{featured.data.summary}</p>
            <p class="meta-line">
              <span>{featured.data.publishDate.toISOString().slice(0, 10)}</span>
              <span>{featured.data.readingTime}</span>
            </p>
            <div class="hero-actions">
              <a class="button button-primary" href={`/fr/blog/${featured.data.slug}`}>
                Lire l’article
              </a>
            </div>
          </article>
        </section>
      )
    }

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">Tous les articles</p>
        <h2>Des formats longs pour les sujets qui demandent un vrai raisonnement.</h2>
      </div>

      <div class="doc-grid">
        {
          rest.map((article) => (
            <article class="doc-card">
              <p class="eyebrow">{article.data.publishDate.toISOString().slice(0, 10)}</p>
              <h3>{article.data.title}</h3>
              <p>{article.data.summary}</p>
              <p class="meta-line">
                <span>{article.data.readingTime}</span>
                <span>{article.data.tags.join(" / ")}</span>
              </p>
              <a class="doc-action" href={`/fr/blog/${article.data.slug}`}>
                Ouvrir l’article
              </a>
            </article>
          ))
        }
      </div>
    </section>
  </main>
  <Footer locale="fr" />
</BaseLayout>
