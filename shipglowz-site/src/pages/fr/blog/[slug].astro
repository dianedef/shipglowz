---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Footer from "../../../components/Footer.astro";
import NavBar from "../../../components/NavBar.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => data.locale === "fr" && !data.draft);

  return articles.map((article) => ({
    params: { slug: article.data.slug },
    props: { article }
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const allArticles = await getCollection("articles", ({ data }) => data.locale === "fr" && !data.draft);
const relatedArticles = allArticles
  .filter((entry) => entry.id !== article.id)
  .slice(0, 3);
---

<BaseLayout
  title={`${article.data.title} | Blog ShipGlowz`}
  description={article.data.description}
  locale="fr"
  canonicalPath={`/fr/blog/${article.data.slug}`}
  alternatePath={`/blog/${article.data.alternateSlug}`}
>
  <main class="page-shell">
    <NavBar locale="fr" currentPath={`/fr/blog/${article.data.slug}`} alternateHref={`/blog/${article.data.alternateSlug}`} />

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">Blog ShipGlowz</p>
        <h1 class="page-title">{article.data.title}</h1>
        <p>{article.data.summary}</p>
        <p class="meta-line">
          <span>{article.data.publishDate.toISOString().slice(0, 10)}</span>
          <span>{article.data.readingTime}</span>
          <span>{article.data.tags.join(" / ")}</span>
        </p>
      </div>
    </section>

    <section class="section">
      <article class="article-shell">
        <Content />
      </article>
    </section>

    {
      relatedArticles.length > 0 && (
        <section class="section">
          <div class="section-heading">
            <p class="eyebrow">À lire ensuite</p>
            <h2>Continuer la logique éditoriale.</h2>
          </div>
          <div class="doc-grid">
            {relatedArticles.map((entry) => (
              <article class="doc-card">
                <h3>{entry.data.title}</h3>
                <p>{entry.data.summary}</p>
                <a class="doc-action" href={`/fr/blog/${entry.data.slug}`}>
                  Ouvrir l’article
                </a>
              </article>
            ))}
          </div>
        </section>
      )
    }
  </main>
  <Footer locale="fr" />
</BaseLayout>
